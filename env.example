# ── Medium ─────────────────────────────────────────────────────────────────────
# No credentials needed! Run `python login.py` to log in via browser.
# Your session is saved to session.json and reused automatically.

# ── Ollama (Local LLM) ────────────────────────────────────────────────────────
# The agent uses Ollama running locally on your machine — no cloud API needed.
# Default model: llama3.2 (good balance of speed and quality)
# Other options: mistral, gemma2, phi3.5, qwen2.5
OLLAMA_MODEL=phi3.5
OLLAMA_BASE_URL=http://localhost:11434

# ── Paywall Bypass ────────────────────────────────────────────────────────────
# Used to access members-only Medium articles for free.
# If the domain stops working, try: readmedium.com, freedium.cfd, archive.today
FREEDIUM_BASE_URL=https://readmedium.com

# ── Gmail ──────────────────────────────────────────────────────────────────────
# How to get app password:
#   1. myaccount.google.com → Security → 2-Step Verification → turn ON
#   2. Then: Security → App passwords → generate one
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_TO=you@gmail.com      # where to send the digest (can be same as above)

# ── Telegram ───────────────────────────────────────────────────────────────────
# How to get bot token:
#   1. Open Telegram → search @BotFather → /newbot → follow prompts → copy token
# How to get chat ID:
#   1. Start a chat with your new bot (send it any message)
#   2. Visit: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#   3. Copy the "id" value inside "chat"
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=987654321
